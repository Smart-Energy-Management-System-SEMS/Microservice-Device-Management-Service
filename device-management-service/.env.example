# =============================================
# SEMS Device Management Service - Variables de entorno
# Copia este archivo como .env y completa los valores
# =============================================

# Puerto del servidor
PORT=8081

# Base de datos - Supabase PostgreSQL
# Formato: jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=jdbc:postgresql://db.TUPROJECTREF.supabase.co:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=TU_PASSWORD_SUPABASE

# JWT - Debe ser el mismo secret que el IAM Service (monolito)
JWT_SECRET=SEMSSecretKeyForJWTTokenGenerationAndValidation2025
JWT_EXPIRATION=86400000

# CORS - Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:4200,http://localhost:3000
